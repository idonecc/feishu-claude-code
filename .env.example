# 飞书应用凭证（在 https://open.feishu.cn/app 创建应用后获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude 默认配置
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_CWD=~

# 工具权限模式：bypassPermissions（跳过所有确认，推荐个人使用）
#              default（需要确认敏感操作）
PERMISSION_MODE=bypassPermissions

# （可选）Claude CLI 路径，留空则自动从 PATH 查找
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# 卡片按钮回调 HTTP 端口（需 ngrok 暴露，见 README「卡片回调」章节）
CALLBACK_PORT=9981

# （可选）ngrok 固定域名，保证重启后回调 URL 不变
# NGROK_DOMAIN=your-domain.ngrok-free.dev

# Claude 子进程出境代理（重要：中国大陆用户必填）
# Anthropic API 对大陆 IP 直连返回 403 Request not allowed，
# launchd/systemd 守护环境没有 shell 的代理变量，必须在这里显式指定。
# 留空则不注入代理（海外服务器可留空）。
CLAUDE_PROXY=http://127.0.0.1:10808
